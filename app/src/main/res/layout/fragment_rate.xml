<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top Header Area (Premium Gradient) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="32dp"
            android:paddingBottom="20dp"
            android:paddingHorizontal="20dp"
            android:background="@drawable/bg_gradient_header">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Milk Rate Settings"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Naya Rate Set Karo (Fat/SNF Matrix)"
                android:textColor="#90CAF9"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- CONTAINER FOR CARDS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- MAIN CONFIGURATION CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_section_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:elevation="4dp">

                <!-- Java ID: etRateDate -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DATE (w.e.f.)" android:textSize="11sp" android:textColor="@color/dairy_blue_light" android:textStyle="bold"/>
                <EditText 
                    android:id="@+id/etRateDate" 
                    android:layout_width="match_parent" 
                    android:layout_height="44dp" 
                    android:hint="YYYY-MM-DD" 
                    android:paddingStart="12dp"
                    android:background="@drawable/bg_input_field"
                    android:textColor="@color/text_dark"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="14dp"/>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E2E8F0" android:layout_marginBottom="12dp"/>

                <!-- BUFFALO RATES SECTION -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="भैंस दर तालिका (Buffalo Rates)" android:textSize="14sp" android:textColor="@color/dairy_blue_primary" android:textStyle="bold" android:layout_marginBottom="8dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2" android:layout_marginBottom="8dp">
                    <!-- Java ID: etBuffFatRate -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingEnd="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kg FAT Rate" android:textSize="10sp" android:textColor="@color/text_muted" android:textStyle="bold"/>
                        <EditText android:id="@+id/etBuffFatRate" android:layout_width="match_parent" android:layout_height="44dp" android:hint="e.g. 875" android:inputType="numberDecimal" android:text="875.00" android:paddingStart="12dp" android:background="@drawable/bg_input_field" android:textColor="@color/text_dark" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <!-- Java ID: etBuffCom -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Com /Liter" android:textSize="10sp" android:textColor="@color/text_muted" android:textStyle="bold"/>
                        <EditText android:id="@+id/etBuffCom" android:layout_width="match_parent" android:layout_height="44dp" android:hint="e.g. 7" android:inputType="numberDecimal" android:text="7.00" android:paddingStart="12dp" android:background="@drawable/bg_input_field" android:textColor="@color/text_dark" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2" android:layout_marginBottom="14dp">
                    <!-- Java ID: etBuffClr -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingEnd="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fix Clr Buff" android:textSize="10sp" android:textColor="@color/text_muted" android:textStyle="bold"/>
                        <EditText android:id="@+id/etBuffClr" android:layout_width="match_parent" android:layout_height="44dp" android:hint="e.g. 29" android:inputType="number" android:text="29" android:paddingStart="12dp" android:background="@drawable/bg_input_field" android:textColor="@color/text_dark" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <!-- Java ID: etBuffSnf -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fix SNF Buff" android:textSize="10sp" android:textColor="@color/text_muted" android:textStyle="bold"/>
                        <EditText android:id="@+id/etBuffSnf" android:layout_width="match_parent" android:layout_height="44dp" android:hint="e.g. 9" android:inputType="numberDecimal" android:text="9.0" android:paddingStart="12dp" android:background="@drawable/bg_input_field" android:textColor="@color/text_dark" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E2E8F0" android:layout_marginBottom="12dp"/>

                <!-- COW RATES SECTION -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="गाय भात पत्रक (Cow Rates)" android:textSize="14sp" android:textColor="@color/dairy_blue_primary" android:textStyle="bold" android:layout_marginBottom="8dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2" android:layout_marginBottom="8dp">
                    <!-- Java ID: etCowFatRate -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingEnd="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kg FAT Rate" android:textSize="10sp" android:textColor="@color/text_muted" android:textStyle="bold"/>
                        <EditText android:id="@+id/etCowFatRate" android:layout_width="match_parent" android:layout_height="44dp" android:hint="e.g. 875" android:inputType="numberDecimal" android:text="875.00" android:paddingStart="12dp" android:background="@drawable/bg_input_field" android:textColor="@color/text_dark" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <!-- Java ID: etCowCom -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Com /Liter" android:textSize="10sp" android:textColor="@color/text_muted" android:textStyle="bold"/>
                        <EditText android:id="@+id/etCowCom" android:layout_width="match_parent" android:layout_height="44dp" android:hint="e.g. 7" android:inputType="numberDecimal" android:text="7.00" android:paddingStart="12dp" android:background="@drawable/bg_input_field" android:textColor="@color/text_dark" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2" android:layout_marginBottom="14dp">
                    <!-- Java ID: etCowClr -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingEnd="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fix Clr Cow" android:textSize="10sp" android:textColor="@color/text_muted" android:textStyle="bold"/>
                        <EditText android:id="@+id/etCowClr" android:layout_width="match_parent" android:layout_height="44dp" android:hint="e.g. 27" android:inputType="number" android:text="27" android:paddingStart="12dp" android:background="@drawable/bg_input_field" android:textColor="@color/text_dark" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <!-- Java ID: etCowSnf -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fix SNF Cow" android:textSize="10sp" android:textColor="@color/text_muted" android:textStyle="bold"/>
                        <EditText android:id="@+id/etCowSnf" android:layout_width="match_parent" android:layout_height="44dp" android:hint="e.g. 8.5" android:inputType="numberDecimal" android:text="8.5" android:paddingStart="12dp" android:background="@drawable/bg_input_field" android:textColor="@color/text_dark" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E2E8F0" android:layout_marginBottom="12dp"/>

                <!-- PROVIDENT FUND SECTION -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PF Deduction (Provident Fund)" android:textSize="13sp" android:textColor="@color/text_dark" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PF per Liter (Rs)" android:textSize="10sp" android:textColor="@color/text_muted" android:textStyle="bold"/>

                <!-- Java ID: etPfPerLiter -->
                <EditText
                    android:id="@+id/etPfPerLiter"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:hint="e.g. 2.00"
                    android:inputType="numberDecimal"
                    android:text="2.00"
                    android:paddingStart="12dp"
                    android:background="@drawable/bg_input_field"
                    android:textColor="@color/text_dark"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠ PF total bill me se cut hoke govt ke through alag pay hoti hai"
                    android:textSize="10.5sp"
                    android:textColor="@color/accent_red"
                    android:layout_marginBottom="14dp"
                    android:textStyle="italic"/>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E2E8F0" android:layout_marginBottom="12dp"/>

                <!-- REMARK / NOTE -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Note" android:textSize="11sp" android:textColor="@color/text_muted" android:textStyle="bold"/>
                <!-- Java ID: etRateNote -->
                <EditText 
                    android:id="@+id/etRateNote" 
                    android:layout_width="match_parent" 
                    android:layout_height="44dp" 
                    android:hint="Optional note..." 
                    android:paddingStart="12dp"
                    android:background="@drawable/bg_input_field"
                    android:textColor="@color/text_dark"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp"/>

                <!-- Java ID: btnSaveRate -->
                <Button 
                    android:id="@+id/btnSaveRate" 
                    android:layout_width="match_parent" 
                    android:layout_height="48dp" 
                    android:text="Rate Save Karo" 
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:backgroundTint="@color/dairy_blue_primary"/>

            </LinearLayout>

            <!-- RATE HISTORY CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_section_card"
                android:padding="16dp"
                android:elevation="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rate History"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"/>

                <!-- Java ID: rateList -->
                <LinearLayout
                    android:id="@+id/rateList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
