<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9F9F6">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="32dp"
            android:paddingBottom="20dp"
            android:paddingHorizontal="20dp"
            android:background="@drawable/bg_gradient_header">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👥 Members Management"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <Button
                android:id="@+id/btnToggleForm"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="➕ JODNE KE LIYE MENU KHOLO"
                android:backgroundTint="#2E6DA4"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:id="@+id/layoutAddMemberForm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_section_card"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:elevation="4dp"
                android:visibility="gone"> <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="➕ Naya Member Jodein"
                    android:textSize="15sp"
                    android:textColor="@color/dairy_blue_primary"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/etMemberCode"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:hint="Member Code (e.g. M001) *"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="12dp"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginBottom="10dp"/>

                <EditText
                    android:id="@+id/etMemberName"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:hint="Member Ka Naam *"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="12dp"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginBottom="10dp"/>

                <EditText
                    android:id="@+id/etFatherHusband"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:hint="Pita / Pati Ka Naam"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="12dp"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginBottom="10dp"/>

                <EditText
                    android:id="@+id/etMemberPhone"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:hint="Mobile Number"
                    android:inputType="phone"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="12dp"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginBottom="10dp"/>

                <EditText
                    android:id="@+id/etMemberAadhar"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:hint="Aadhaar No."
                    android:inputType="number"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="12dp"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginBottom="10dp"/>

                <EditText
                    android:id="@+id/etJanAadhar"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:hint="Jan Aadhaar No."
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="12dp"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginBottom="10dp"/>

                <EditText
                    android:id="@+id/etMemberUniqueId"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:hint="Unique ID No. *"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="12dp"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginBottom="10dp"/>

                <EditText
                    android:id="@+id/etBankName"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:hint="Bank Ka Naam"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="12dp"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginBottom="10dp"/>

                <EditText
                    android:id="@+id/etBankAcc"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:hint="Bank Account No."
                    android:inputType="number"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="12dp"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginBottom="10dp"/>

                <EditText
                    android:id="@+id/etIfsc"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:hint="IFSC Code"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="12dp"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginBottom="14dp"/>

                <Button
                    android:id="@+id/btnAddMember"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="SAVE MEMBER"
                    android:backgroundTint="#1A3A5C"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_section_card"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:elevation="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋 All Members List (Detailed)"
                    android:textSize="15sp"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:id="@+id/membersContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:gravity="center">

                <Button
                    android:id="@+id/btnExportPdf"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="📄 PDF"
                    android:textSize="12sp"
                    android:backgroundTint="@color/accent_red"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"/>

                <Button
                    android:id="@+id/btnExportExcel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:text="📊 EXCEL"
                    android:textSize="12sp"
                    android:backgroundTint="#1A3A5C"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"/>

                <Button
                    android:id="@+id/btnPrintList"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="🖨 PRINT"
                    android:textSize="12sp"
                    android:backgroundTint="#1A3A5C"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"/>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
