<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F9F9F6">

    <!-- Premium Blue Gradient Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="32dp"
        android:paddingBottom="24dp"
        android:paddingHorizontal="20dp"
        android:background="@drawable/bg_gradient_header">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Apni Dairy"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Java Variable ID: tvBanner -->
        <TextView
            android:id="@+id/tvBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="June 2026 · Sab kuch theek hai ✓"
            android:textColor="#90CAF9"
            android:textSize="12sp"
            android:layout_marginTop="2dp"
            android:padding="4dp" />

        <!-- Quick Mini Stats Row Inside Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <!-- Stat 1: Total Members (tvMembers) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#1AFFFFFF"
                android:padding="8dp"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MEMBERS" android:textColor="#B3FFFFFF" android:textSize="9sp" android:textStyle="bold"/>
                <TextView android:id="@+id/tvMembers" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- Stat 2: Aaj Ka Doodh (tvToday) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#1AFFFFFF"
                android:padding="8dp"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_marginLeft="6dp"
                android:layout_marginRight="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AAJ DOODH" android:textColor="#B3FFFFFF" android:textSize="9sp" android:textStyle="bold"/>
                <TextView android:id="@+id/tvToday" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0L" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- Stat 3: Is Mahine Ka Doodh (tvMonth) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#1AFFFFFF"
                android:padding="8dp"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="IS MAHINE" android:textColor="#B3FFFFFF" android:textSize="9sp" android:textStyle="bold"/>
                <TextView android:id="@+id/tvMonth" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0L" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Stat Card 4: Total Baaki (tvBaaki) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:padding="14dp"
                android:background="@drawable/bg_section_card"
                android:elevation="2dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="कुल बकाया राशि (Total Outstanding):" android:textColor="@color/text_muted" android:textStyle="bold" android:textSize="13sp"/>
                <TextView android:id="@+id/tvBaaki" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="₹0" android:textColor="@color/accent_red" android:textStyle="bold" android:textSize="15sp"/>
            </LinearLayout>

            <!-- Financial Calculation Section Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:padding="16dp"
                android:background="@drawable/bg_section_card"
                android:elevation="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅 Mahine Ka Hisaab"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kul Doodh" android:textColor="@color/text_muted" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvMonthMilk" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 L" android:textColor="@color/text_dark" android:textStyle="bold" android:layout_alignParentEnd="true"/>
                </RelativeLayout>

                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kul Revenue" android:textColor="@color/text_muted" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvMonthRev" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="₹ 0" android:textColor="@color/accent_green" android:textStyle="bold" android:layout_alignParentEnd="true"/>
                </RelativeLayout>

                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Total Outstanding" android:textColor="@color/text_muted" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvTotalBaaki" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="₹ 0" android:textColor="@color/accent_red" android:textStyle="bold" android:layout_alignParentEnd="true"/>
                </RelativeLayout>
            </LinearLayout>

            <!-- Dynamic Baaki Members List Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:padding="16dp"
                android:background="@drawable/bg_section_card"
                android:elevation="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️ Udhaar / Baaki List"
                    android:textColor="@color/accent_red"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <!-- Java Dynamic Container ID: baakiList -->
                <LinearLayout
                    android:id="@+id/baakiList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
