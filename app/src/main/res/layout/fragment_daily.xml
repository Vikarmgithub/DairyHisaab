<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- GREEN GRADIENT HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="32dp"
        android:paddingBottom="16dp"
        android:paddingHorizontal="20dp"
        android:background="@drawable/bg_gradient_header">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Daily Entry"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvRateBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Loading rates..."
            android:textColor="#C8E6C9"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />

        <!-- Date Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/btnPrevDay"
                android:layout_width="36dp"
                android:layout_height="32dp"
                android:text="◀"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="#33FFFFFF"
                android:clickable="true"
                android:focusable="true"/>

            <EditText
                android:id="@+id/etDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:focusable="false"
                android:clickable="true"
                android:hint="Select Date"
                android:textColorHint="#B3FFFFFF"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@android:color/transparent"/>

            <TextView
                android:id="@+id/btnNextDay"
                android:layout_width="36dp"
                android:layout_height="32dp"
                android:text="▶"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="#33FFFFFF"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- Subah / Shaam Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:orientation="horizontal"
            android:background="#26FFFFFF"
            android:padding="3dp"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/btnMorning"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="🌅 Subah"
                android:gravity="center"
                android:textColor="#1A3A5C"
                android:background="@color/white"
                android:textStyle="bold"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/btnEvening"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="🌆 Shaam"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
    </LinearLayout>

    <!-- QUICK ENTRY INPUT BOX -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:elevation="4dp">

        <!-- Row 1: Code + Name + Animal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <EditText
                android:id="@+id/etQuickCode"
                android:layout_width="80dp"
                android:layout_height="44dp"
                android:hint="Code"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:inputType="text"
                android:background="@drawable/bg_search_box"
                android:paddingHorizontal="8dp"
                android:imeOptions="actionNext"/>

            <TextView
                android:id="@+id/tvQuickName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="— Member naam —"
                android:textSize="13sp"
                android:textColor="#9E9E9E"
                android:textStyle="bold"
                android:layout_marginHorizontal="10dp"/>

            <TextView
                android:id="@+id/tvAnimalToggle"
                android:layout_width="60dp"
                android:layout_height="36dp"
                android:text="भैंस"
                android:gravity="center"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="#1A3A5C"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- Row 2: Qty + Fat + Amount + Save -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/etQuickQty"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:hint="Qty L"
                android:textSize="13sp"
                android:gravity="center"
                android:inputType="numberDecimal"
                android:background="@drawable/bg_search_box"
                android:imeOptions="actionNext"/>

            <EditText
                android:id="@+id/etQuickFat"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:hint="Fat %"
                android:textSize="13sp"
                android:gravity="center"
                android:inputType="numberDecimal"
                android:background="@drawable/bg_search_box"
                android:layout_marginHorizontal="6dp"
                android:imeOptions="actionDone"/>

            <TextView
                android:id="@+id/tvQuickAmount"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="₹0.00"
                android:gravity="center"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#2E6DA4"
                android:background="#EBF3FB"/>

            <Button
                android:id="@+id/btnQuickSave"
                android:layout_width="56dp"
                android:layout_height="44dp"
                android:text="✔"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2E6DA4"
                android:layout_marginStart="6dp"
                android:padding="0dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- COLUMN HEADERS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#EBF3FB"
        android:paddingHorizontal="12dp"
        android:paddingVertical="7dp">

        <TextView
            android:layout_width="42dp"
            android:layout_height="wrap_content"
            android:text="Code"
            android:textColor="#1A3A5C"
            android:textStyle="bold"
            android:textSize="10sp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="Member"
            android:textColor="#1A3A5C"
            android:textStyle="bold"
            android:textSize="10sp"/>

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="Milk"
            android:gravity="center"
            android:textColor="#1A3A5C"
            android:textStyle="bold"
            android:textSize="10sp"/>

        <TextView
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:text="Fat"
            android:gravity="center"
            android:textColor="#1A3A5C"
            android:textStyle="bold"
            android:textSize="10sp"/>

        <TextView
            android:layout_width="42dp"
            android:layout_height="wrap_content"
            android:text="Rate"
            android:gravity="center"
            android:textColor="#1A3A5C"
            android:textStyle="bold"
            android:textSize="10sp"/>

        <TextView
            android:layout_width="44dp"
            android:layout_height="wrap_content"
            android:text="PF Ded"
            android:gravity="center"
            android:textColor="#C62828"
            android:textStyle="bold"
            android:textSize="10sp"/>

        <TextView
            android:layout_width="56dp"
            android:layout_height="wrap_content"
            android:text="Net Amt"
            android:gravity="end"
            android:textColor="#1A3A5C"
            android:textStyle="bold"
            android:textSize="10sp"/>

        <TextView
            android:layout_width="44dp"
            android:layout_height="wrap_content"
            android:text="Del"
            android:gravity="center"
            android:textColor="#9E9E9E"
            android:textStyle="bold"
            android:textSize="10sp"/>
    </LinearLayout>

    <!-- ENTRY LIST -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/entryList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="8dp"/>
    </ScrollView>

    <!-- BOTTOM TOTAL + PRINT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1A3A5C"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvTotalSummary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Total: 0 entries | ₹0.00"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="11sp"/>

        <Button
            android:id="@+id/btnPrintSlip"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="🖨 Print Slip"
            android:textColor="#1A3A5C"
            android:backgroundTint="#FFFFFF"
            android:textSize="12sp"
            android:padding="8dp"/>
    </LinearLayout>

</LinearLayout>
