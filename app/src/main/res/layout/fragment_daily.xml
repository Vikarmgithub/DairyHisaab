<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F7FC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="32dp"
        android:paddingBottom="16dp"
        android:paddingHorizontal="20dp"
        android:background="@drawable/bg_gradient_header">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Daily Entry"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvRateBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Loading active milk rates..."
            android:textColor="#90CAF9"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />

        <EditText
            android:id="@+id/etDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:focusable="false"
            android:clickable="true"
            android:hint="Select Date"
            android:textColorHint="#B3FFFFFF"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@android:color/transparent"
            android:layout_marginTop="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:orientation="horizontal"
            android:background="#26FFFFFF"
            android:padding="3dp"
            android:layout_marginTop="12dp">
            
            <TextView
                android:id="@+id/btnMorning"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="🌅 Subah"
                android:gravity="center"
                android:textColor="#212121"
                android:background="@color/white"
                android:textStyle="bold"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true"/>
                
            <TextView
                android:id="@+id/btnEvening"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="🌆 Shaam"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/input_bg_blue"
        android:padding="10dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp">
        <TextView android:layout_width="30dp" android:layout_height="wrap_content" android:text="#" android:textColor="@color/dairy_blue_light" android:textStyle="bold" android:textSize="11sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Member" android:textColor="@color/dairy_blue_light" android:textStyle="bold" android:textSize="11sp"/>
        <TextView android:layout_width="50dp" android:layout_height="wrap_content" android:text="Qty L" android:gravity="center" android:textColor="@color/dairy_blue_light" android:textStyle="bold" android:textSize="11sp"/>
        <TextView android:layout_width="40dp" android:layout_height="wrap_content" android:text="Fat" android:gravity="center" android:textColor="@color/dairy_blue_light" android:textStyle="bold" android:textSize="11sp"/>
        <TextView android:layout_width="60dp" android:layout_height="wrap_content" android:text="Total ₹" android:gravity="end" android:textColor="@color/dairy_blue_light" android:textStyle="bold" android:textSize="11sp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:id="@+id/entryList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp" />
    </ScrollView>

    <Button
        android:id="@+id/btnSaveAll"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="💾 Save All Entries"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:backgroundTint="@color/dairy_blue_primary"
        android:layout_margin="16dp"/>
</LinearLayout>
