<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- ===== HEADER ===== -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_dark_blue"
        android:paddingTop="24dp"
        android:paddingBottom="12dp"
        android:paddingHorizontal="12dp">

        <TextView
            android:id="@+id/tvAppTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dairy Hisaab Kitab"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_toStartOf="@+id/btnSettings"
            android:layout_toEndOf="@+id/tvPaddingStart"/>

        <!-- Invisible start padding placeholder -->
        <View
            android:id="@+id/tvPaddingStart"
            android:layout_width="40dp"
            android:layout_height="1dp"
            android:layout_alignParentStart="true"/>

        <!-- ⚙️ Settings icon (top-right) -->
        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_preferences"
            android:tint="#FFFFFF"
            android:contentDescription="Settings"/>

    </RelativeLayout>

    <!-- Demo countdown timer (hidden jab demo nahi chal rha) -->
    <TextView
        android:id="@+id/tvDemoTimer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FF6F00"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingVertical="4dp"
        android:visibility="gone"/>

    <!-- ===== TAB BAR ===== -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_dark_blue"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="6dp"
            android:paddingBottom="8dp">

            <Button
                android:id="@+id/tab_dashboard"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="Home"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_input_field"
                android:backgroundTint="@color/dairy_blue_light"
                android:textColor="#FFFFFF"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginHorizontal="3dp"/>

            <Button
                android:id="@+id/tab_members"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="Members"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_input_field"
                android:backgroundTint="#1A3A5C"
                android:textColor="#90CAF9"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginHorizontal="3dp"/>

            <Button
                android:id="@+id/tab_daily"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="Daily"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_input_field"
                android:backgroundTint="#1A3A5C"
                android:textColor="#90CAF9"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginHorizontal="3dp"/>

            <Button
                android:id="@+id/tab_payments"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="Payments"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_input_field"
                android:backgroundTint="#1A3A5C"
                android:textColor="#90CAF9"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginHorizontal="3dp"/>

            <Button
                android:id="@+id/tab_rate"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="Rate"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_input_field"
                android:backgroundTint="#1A3A5C"
                android:textColor="#90CAF9"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginHorizontal="3dp"/>

            <Button
                android:id="@+id/tab_reports"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="Reports"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_input_field"
                android:backgroundTint="#1A3A5C"
                android:textColor="#90CAF9"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginHorizontal="3dp"/>

            <Button
                android:id="@+id/tab_backup"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="Settings"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_input_field"
                android:backgroundTint="#1A3A5C"
                android:textColor="#90CAF9"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginHorizontal="3dp"/>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- ===== CONTENT PAGER ===== -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>
