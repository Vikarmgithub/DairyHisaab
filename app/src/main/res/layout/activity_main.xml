<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F7FC">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Dairy Hisaab Kitab"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingTop="24dp"
        android:paddingBottom="16dp"
        android:background="@color/bg_dark_blue"/>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_dark_blue"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="6dp"
            android:paddingBottom="8dp">

            <Button
                android:id="@+id/tab_dashboard"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="Home"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_input_field"
                android:backgroundTint="@color/dairy_blue_light"
                android:textColor="#FFFFFF"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginHorizontal="3dp"/>

            <Button
                android:id="@+id/tab_members"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="Members"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_input_field"
                android:backgroundTint="#102A54"
                android:textColor="#90CAF9"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginHorizontal="3dp"/>

            <Button
                android:id="@+id/tab_daily"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="Daily"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_input_field"
                android:backgroundTint="#102A54"
                android:textColor="#90CAF9"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginHorizontal="3dp"/>

            <Button
                android:id="@+id/tab_payments"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="Payments"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_input_field"
                android:backgroundTint="#102A54"
                android:textColor="#90CAF9"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginHorizontal="3dp"/>

            <Button
                android:id="@+id/tab_rate"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="Rate"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_input_field"
                android:backgroundTint="#102A54"
                android:textColor="#90CAF9"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginHorizontal="3dp"/>

            <Button
                android:id="@+id/tab_reports"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="Reports"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_input_field"
                android:backgroundTint="#102A54"
                android:textColor="#90CAF9"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginHorizontal="3dp"/>

            <Button
                android:id="@+id/tab_backup"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="Backup"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_input_field"
                android:backgroundTint="#102A54"
                android:textColor="#90CAF9"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginHorizontal="3dp"/>

        </LinearLayout>
    </HorizontalScrollView>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>