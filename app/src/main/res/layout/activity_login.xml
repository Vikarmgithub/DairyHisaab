<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F0"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp">

        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@mipmap/ic_launcher"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dairy Hisaab Kitab"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#5D3A1A"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Apne dairy ka hisaab — aasaan aur surakshit"
            android:textSize="14sp"
            android:textColor="#8B6347"
            android:gravity="center"
            android:layout_marginBottom="32dp"/>

        <!-- EMAIL INPUT -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_input_field">
            <TextView
                android:id="@+id/iconEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📧"
                android:layout_centerVertical="true"
                android:layout_marginStart="14dp" />
            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_toEndOf="@id/iconEmail"
                android:background="@android:color/transparent"
                android:hint="Email daalo"
                android:textColorHint="#AAAAAA"
                android:textColor="#333333"
                android:textSize="13sp"
                android:paddingStart="10dp"
                android:inputType="textEmailAddress" />
        </RelativeLayout>

        <!-- PASSWORD INPUT -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_input_field">
            <TextView
                android:id="@+id/iconPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔒"
                android:layout_centerVertical="true"
                android:layout_marginStart="14dp" />
            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_toEndOf="@id/iconPassword"
                android:background="@android:color/transparent"
                android:hint="Password daalo"
                android:textColorHint="#AAAAAA"
                android:textColor="#333333"
                android:textSize="13sp"
                android:paddingStart="10dp"
                android:inputType="textPassword" />
        </RelativeLayout>

        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Login Karo"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#5D3A1A"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Register Karo"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#5D3A1A"
            android:visibility="gone"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Naya account banao? Register karo"
            android:textColor="#DB4437"
            android:textSize="14sp"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="— Ya —"
            android:textColor="#999999"
            android:layout_marginBottom="20dp"/>

        <!-- NAME INPUT -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_input_field"
        android:visibility="gone"
        android:id="@+id/layoutName">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👤"
            android:layout_centerVertical="true"
            android:layout_marginStart="14dp" />
        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:hint="Apna naam daalo"
            android:textColorHint="#AAAAAA"
            android:textColor="#333333"
            android:textSize="15sp"
            android:paddingStart="10dp"
            android:inputType="textPersonName" />
    </RelativeLayout>

    <!-- PHONE NUMBER INPUT -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_input_field">
            <TextView
                android:id="@+id/iconPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📱"
                android:layout_centerVertical="true"
                android:layout_marginStart="14dp" />
            <EditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_toEndOf="@id/iconPhone"
                android:background="@android:color/transparent"
                android:hint="+91 Mobile Number daalo"
                android:textColorHint="#AAAAAA"
                android:textColor="#333333"
                android:textSize="13sp"
                android:paddingStart="10dp"
                android:inputType="phone"
                android:maxLength="13" />
        </RelativeLayout>

        <Button
            android:id="@+id/btnSendOtp"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="OTP Bhejo"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2E7D32"
            android:layout_marginBottom="12dp"/>

        <!-- OTP VERIFY SECTION — pehle hidden -->
        <LinearLayout
            android:id="@+id/layoutOtpVerify"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_input_field">
                <TextView
                    android:id="@+id/iconOtp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔢"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="14dp" />
                <EditText
                    android:id="@+id/etOtp"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_toEndOf="@id/iconOtp"
                    android:background="@android:color/transparent"
                    android:hint="6 digit OTP daalo"
                    android:textColorHint="#AAAAAA"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    android:paddingStart="10dp"
                    android:inputType="numberPassword"
                    android:maxLength="6" />
            </RelativeLayout>

            <Button
                android:id="@+id/btnVerifyOtp"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="OTP Verify Karo"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1565C0"
                android:layout_marginBottom="8dp"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tvResendOtp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OTP nahi aaya? Dobara bhejo"
            android:textColor="#1565C0"
            android:textSize="13sp"
            android:visibility="gone"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="— Ya —"
            android:textColor="#999999"
            android:layout_marginBottom="20dp"/>

        <!-- GOOGLE SIGN IN -->
        <Button
            android:id="@+id/btnGoogleSignIn"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Google se Login Karo"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#DB4437"
            android:layout_marginBottom="8dp"/>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginTop="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aapka data sirf aapke account mein save hota hai"
            android:textSize="12sp"
            android:textColor="#999999"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp"/>

    </LinearLayout>
</ScrollView>
