<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="32dp"
            android:paddingBottom="20dp"
            android:paddingHorizontal="20dp"
            android:background="@drawable/bg_gradient_header">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚙️ Settings"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Backup, restore aur security settings"
                android:textColor="#90CAF9"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- OPTIONS LIST -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Account Status -->
            <TextView
                android:id="@+id/tvGoogleAccount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="❌ Login nahi hai"
                android:textSize="13sp"
                android:textColor="@color/text_muted"
                android:background="@drawable/bg_section_card"
                android:padding="14dp"
                android:layout_marginBottom="10dp"
                android:elevation="2dp"/>

            <!-- 1. PIN Change -->
            <Button
                android:id="@+id/btnChangePin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🔑 PIN Change / Set Karo"
                android:backgroundTint="#1a3c5e"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="10dp"/>

            <!-- 2. Cloud Backup -->
            <Button
                android:id="@+id/btnDriveBackup"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="☁️ Cloud Backup Karo"
                android:backgroundTint="@color/dairy_blue_primary"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="10dp"/>

            <!-- 3. Cloud Restore -->
            <Button
                android:id="@+id/btnDriveRestore"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="⬇️ Cloud Se Restore Karo"
                android:backgroundTint="@color/dairy_blue_light"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="10dp"/>

            <!-- 4. Local Backup -->
            <Button
                android:id="@+id/btnBackup"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="💾 Local Backup Karo"
                android:backgroundTint="@color/dairy_blue_dark"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="10dp"/>

            <!-- 5. File Restore -->
            <Button
                android:id="@+id/btnRestore"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="📂 File Se Restore Karo"
                android:backgroundTint="#455A64"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="10dp"/>

            <!-- 6. Sign Out (only visible when logged in) -->
            <Button
                android:id="@+id/btnSignOut"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🔓 Cloud Account Sign Out"
                android:backgroundTint="#78909C"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="10dp"
                android:visibility="gone"/>

            <!-- 7. Logout (sabse niche) -->
            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🚪 Logout"
                android:backgroundTint="#C62828"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="15sp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"/>

            <!-- Data Status - bottom right info -->
            <TextView
                android:id="@+id/tvDataStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="Loading..."
                android:textSize="11sp"
                android:textColor="#9E9E9E"
                android:fontFamily="monospace"
                android:gravity="end"
                android:layout_marginBottom="8dp"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
